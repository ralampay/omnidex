# Copy to .env and update values as needed.

# Required for the local orchestrator
OMNIDEX_LLAMA_MODEL_PATH=/absolute/path/to/model.gguf

# Optional tuning
# Device selection. Supported values: cpu, gpu
OMNIDEX_DEVICE=cpu

# Runtime context length. Default: 8192
# OMNIDEX_LLAMA_CTX=8192
# Thread count. Leave unset for dynamic selection, or set an integer to
# override explicitly.
# OMNIDEX_LLAMA_THREADS=8
# Optional override. If OMNIDEX_DEVICE=gpu and this is unset, all layers are
# offloaded to CUDA by default.
# OMNIDEX_LLAMA_GPU_LAYERS=-1
# Silence llama-cpp-python logs by default.
OMNIDEX_LLAMA_VERBOSE=0

# Render agent output as Markdown in the CLI.
OMNIDEX_RENDER_MARKDOWN=1

# Stream tokens with a Rich Live panel (set to 0 to disable).
OMNIDEX_STREAM=0

# Recent message window size for short-term memory.
# OMNIDEX_SHORT_TERM_LIMIT=5

# Optional override for persistent long-term memory storage.
# OMNIDEX_MEMORY_PATH=.omnidex/orchestrator_memory.json
